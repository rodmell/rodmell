generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MANAGER
  SELLER
  ADMIN_STAFF
  WORKSHOP
}

enum EstadoVehiculo {
  DISPONIBLE
  RESERVADO
  VENDIDO
  ENTREGADO
  CONSIGNADO
}

enum TipoVehiculo {
  AUTO
  MOTO
}

enum MedioPago {
  SENA
  TRANSFERENCIA
  EFECTIVO
  TARJETA
  OTROS
}

enum EstadoCuota {
  PENDIENTE
  PAGADA
  VENCIDA
}

enum ConceptoGasto {
  PATENTE
  INSCRIPCION
  PRENDA
  GESTORIA
  ACCESORIOS
  OTROS
}

enum TipoDocumento {
  DNI
  FORMULARIO
  CONTRATO
  PDF
  OTRO
}

model User {
  id            String      @id @default(cuid())
  name          String
  username      String      @unique
  password      String
  role          Role        @default(SELLER)
  phone         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  operaciones   Operacion[]
  activityLogs  ActivityLog[]
}

model Cliente {
  id             String      @id @default(cuid())
  nombreCompleto String
  dni            String?
  cuil           String?
  estadoCivil    String?
  conyuge        String?
  direccion      String?
  telefono       String?
  email          String?
  observaciones  String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  operaciones    Operacion[]
  documentos     Documento[]
}

model Vehiculo {
  id           String         @id @default(cuid())
  tipo         TipoVehiculo   @default(AUTO)
  marca        String
  modelo       String
  anio         Int
  dominio      String
  chasis       String?
  color        String?
  kilometros   Int?
  precioVenta  Float
  precioCosto  Float?
  precioFactura Float?
  precioUSD    Float?
  condicion    String?
  combustible  String?
  descripcion  String?
  estado       EstadoVehiculo @default(DISPONIBLE)
  fotos        String[]       // Array of image URLs
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  operaciones  Operacion[]
  documentos   Documento[]
}

model Operacion {
  id                String    @id @default(cuid())
  clienteId         String
  vehiculoId        String
  vendedorId        String
  precioVehiculo    Float
  formaPago         String?
  efectivo          Float?
  credito           Float?
  autoPartePago     Float?
  detalleAutoPartePago String?
  porcentajeQuebranto Float?
  gastosInscripcion Float?
  gastosPrenda      Float?
  accesorios        Float?
  quebranto         Float?
  gastosPatente     Float?
  gastosTransferencia Float?
  gastosPrendarios   Float?
  confirmado        Boolean   @default(false)
  observaciones     String?
  total             Float
  saldoPendiente    Float
  comprobante       String?   @unique
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  cliente           Cliente   @relation(fields: [clienteId], references: [id])
  vehiculo          Vehiculo  @relation(fields: [vehiculoId], references: [id])
  vendedor          User      @relation(fields: [vendedorId], references: [id])

  pagos             Pago[]
  cuotas            Cuota[]
  gastos            Gasto[]
  documentos        Documento[]
}

model Pago {
  id              String    @id @default(cuid())
  operacionId     String
  fecha           DateTime
  importe         Float
  medioPago       MedioPago
  observaciones   String?
  comprobante     String?   @unique
  comprobanteUrl  String?

  operacion       Operacion @relation(fields: [operacionId], references: [id])
}

model Cuota {
  id               String      @id @default(cuid())
  operacionId      String
  numeroCuota      Int
  valor            Float
  fechaVencimiento DateTime
  estado           EstadoCuota @default(PENDIENTE)
  medioPago        MedioPago?
  fechaPago        DateTime?
  comprobante      String?     @unique
  comprobanteUrl   String?

  operacion        Operacion   @relation(fields: [operacionId], references: [id])
}

model Gasto {
  id           String        @id @default(cuid())
  operacionId  String
  concepto     ConceptoGasto
  monto        Float
  fecha        DateTime

  operacion    Operacion     @relation(fields: [operacionId], references: [id])
}

model Documento {
  id            String        @id @default(cuid())
  operacionId   String?
  clienteId     String?
  vehiculoId    String?
  tipo          TipoDocumento
  url           String
  nombreArchivo String
  observaciones String?

  operacion     Operacion?    @relation(fields: [operacionId], references: [id])
  cliente       Cliente?      @relation(fields: [clienteId], references: [id])
  vehiculo      Vehiculo?     @relation(fields: [vehiculoId], references: [id])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String   // e.g., "CREATE_VEHICLE", "UPDATE_CUSTOMER"
  details   String?  // e.g., "Added Audi A4 (DOM-123)"
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}
